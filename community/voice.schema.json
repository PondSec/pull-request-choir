{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pull Request Choir Voice",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "handle", "displayName", "phrase", "mood", "note", "color", "respondsTo"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,38}[a-z0-9]$"
    },
    "handle": {
      "type": "string",
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 40
    },
    "phrase": {
      "type": "string",
      "minLength": 12,
      "maxLength": 140
    },
    "mood": {
      "enum": ["wonder", "hope", "defiance", "focus", "calm", "joy", "chaos"]
    },
    "note": {
      "enum": ["C3", "D3", "E3", "F3", "G3", "A3", "B3", "C4", "D4", "E4", "F4", "G4", "A4", "B4", "C5", "D5", "E5", "F5", "G5", "A5"]
    },
    "color": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    },
    "respondsTo": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]{1,38}[a-z0-9]$"
      }
    }
  }
}
